rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /student_photos/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    match /student_docs/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
